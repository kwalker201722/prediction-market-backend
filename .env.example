# Application
NODE_ENV=development
PORT=3000

# Frontend URL (for CORS and Stripe redirects)
CORS_ORIGIN=http://localhost:3001
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/prediction_market

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_at_least_32_chars
JWT_EXPIRES_IN=15m

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Ethereum / Blockchain
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
SMART_CONTRACT_ADDRESS=0xE88582edFEc4CFb3B1A3ABa5A79c55B8C1d770fc
SMART_CONTRACT_ABI=[]

# Backend wallet (used to execute on-chain transactions)
# WARNING: Store this securely, never commit the actual key
BACKEND_WALLET_PRIVATE_KEY=your_private_key_here

# -----------------------------------------------------------------------
# Oracle Settlement Bot (oracle-bot/settlement-bot.ts)
# -----------------------------------------------------------------------

# Override RPC / contract / key for the bot (falls back to the values above)
ORACLE_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
ORACLE_CONTRACT_ADDRESS=0xE88582edFEc4CFb3B1A3ABa5A79c55B8C1d770fc
ORACLE_PRIVATE_KEY=your_oracle_private_key_here

# Set to "true" to log payloads without sending any transactions
DRY_RUN=false

# Price data providers (at least one recommended)
POLYGON_API_KEY=your_polygon_api_key_here
FMP_API_KEY=your_fmp_api_key_here
# Yahoo Finance requires no API key

# Markets to settle – JSON array of MarketConfig objects.
# In production, replace with a DB query in loadMarketsToSettle().
# Example:
# MARKETS_TO_SETTLE=[{"marketId":"1","ticker":"AAPL","expiryDate":"2024-01-19"}]
MARKETS_TO_SETTLE=[]
