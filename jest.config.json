{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/oracle-bot"],
  "testMatch": ["**/*.test.ts"],
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "tsconfig": {
          "rootDir": ".",
          "strict": true,
          "esModuleInterop": true,
          "target": "ES2020",
          "module": "commonjs",
          "skipLibCheck": true,
          "resolveJsonModule": true
        }
      }
    ]
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "oracle-bot/**/*.ts",
    "!src/migrations/**"
  ],
  "coverageDirectory": "coverage"
}
